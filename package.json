{
  "name": "birss-app",
  "private": true,
  "version": "0.7.1",
  "description": "Calculates non-zero susceptibility tensor components (Electric Dipole, Magnetic Dipole, Electric Quadrupole) and induced transverse SHG source terms for all 32 crystallographic and 122 magnetic point groups.",
  "author": "Thomas Lottermoser",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/manganite/birss-app.git"
  },
  "homepage": "https://manganite.github.io/birss-app/",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.1.14",
    "@vitejs/plugin-react": "5.0.4",
    "katex": "0.16.44",
    "lucide-react": "0.546.0",
    "motion": "12.23.24",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-katex": "3.1.0",
    "recharts": "3.8.1",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@types/katex": "0.16.8",
    "@types/node": "22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-katex": "3.0.4",
    "autoprefixer": "10.4.21",
    "gh-pages": "6.3.0",
    "tailwindcss": "4.1.14",
    "typescript": "5.8.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  }
}
